<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp2.Pages.PlacesPage"
             Title="Khám Phá Quán Ăn"
             xmlns:models="clr-namespace:TourGuideApp2.Models">

    <CollectionView ItemsSource="{Binding Places}" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Stroke="LightGray" StrokeThickness="1" StrokeShape="RoundRectangle 12" Margin="10" Padding="10" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Radius="8" Opacity="0.2" Offset="4,4"/>
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="15">
                        <Image Source="{Binding ImageUrl}" WidthRequest="120" HeightRequest="120" Aspect="AspectFill" />
                        <VerticalStackLayout Spacing="8">
                            <!-- Thay CenterAndExpand bằng Center + HeightRequest nếu cần expand, hoặc wrap trong Grid nếu phức tạp -->
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#FF6B35" />
                            <Label Text="{Binding Specialty}" FontSize="14" TextColor="Gray" MaxLines="2" LineBreakMode="WordWrap" />
                            <Label Text="{Binding Address}" FontSize="12" TextColor="DarkGray" />
                            <Button Text="Xem chi tiết" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#FF6B35" TextColor="White" CornerRadius="20" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>